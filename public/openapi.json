{
    "openapi": "3.1.0",
    "info": {
        "title": "Laravel-Test API Docs",
        "version": "1.0.0",
        "description": "Translation management API documentation generated by Scramble."
    },
    "servers": [
        {
            "url": "http://localhost:8000/api"
        }
    ],
    "security": [
        {
            "bearer": []
        }
    ],
    "paths": {
        "/tokens": {
            "post": {
                "operationId": "tokens.store",
                "description": "Exchange a valid email and password for a personal access token that can\nbe used as a Bearer token on the protected translation endpoints.",
                "summary": "Issue a bearer token for API access",
                "tags": [
                    "AccessToken"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/IssueAccessTokenRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "token": {
                                            "type": "string"
                                        },
                                        "token_type": {
                                            "type": "string",
                                            "const": "Bearer"
                                        },
                                        "expires_at": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "token",
                                        "token_type",
                                        "expires_at"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                },
                "security": []
            }
        },
        "/translations/export": {
            "get": {
                "operationId": "translations.export",
                "description": "Return frontend-ready nested JSON translation payloads for one locale or\nall locales, with optional tag filtering.",
                "summary": "Export translations",
                "tags": [
                    "Translation"
                ],
                "parameters": [
                    {
                        "name": "locale",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$",
                            "maxLength": 12
                        }
                    },
                    {
                        "name": "tags[]",
                        "in": "query",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "maxLength": 64
                            }
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "additionalProperties": {}
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/translations": {
            "get": {
                "operationId": "translations.index",
                "description": "Return a paginated translation list filtered by locale, key, content,\nand optional context tags.",
                "summary": "Search translations",
                "tags": [
                    "Translation"
                ],
                "parameters": [
                    {
                        "name": "locale",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$",
                            "maxLength": 12
                        }
                    },
                    {
                        "name": "key",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "maxLength": 191
                        }
                    },
                    {
                        "name": "content",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "tags[]",
                        "in": "query",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "maxLength": 64
                            }
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 100
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated set of `TranslationResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/TranslationCollection"
                                        },
                                        {
                                            "type": "object",
                                            "properties": {
                                                "links": {
                                                    "type": "object",
                                                    "properties": {
                                                        "first": {
                                                            "type": [
                                                                "string",
                                                                "null"
                                                            ]
                                                        },
                                                        "last": {
                                                            "type": [
                                                                "string",
                                                                "null"
                                                            ]
                                                        },
                                                        "prev": {
                                                            "type": [
                                                                "string",
                                                                "null"
                                                            ]
                                                        },
                                                        "next": {
                                                            "type": [
                                                                "string",
                                                                "null"
                                                            ]
                                                        }
                                                    },
                                                    "required": [
                                                        "first",
                                                        "last",
                                                        "prev",
                                                        "next"
                                                    ]
                                                },
                                                "meta": {
                                                    "type": "object",
                                                    "properties": {
                                                        "current_page": {
                                                            "type": "integer",
                                                            "minimum": 1
                                                        },
                                                        "from": {
                                                            "type": [
                                                                "integer",
                                                                "null"
                                                            ],
                                                            "minimum": 1
                                                        },
                                                        "last_page": {
                                                            "type": "integer",
                                                            "minimum": 1
                                                        },
                                                        "links": {
                                                            "type": "array",
                                                            "description": "Generated paginator links.",
                                                            "items": {
                                                                "type": "object",
                                                                "properties": {
                                                                    "url": {
                                                                        "type": [
                                                                            "string",
                                                                            "null"
                                                                        ]
                                                                    },
                                                                    "label": {
                                                                        "type": "string"
                                                                    },
                                                                    "active": {
                                                                        "type": "boolean"
                                                                    }
                                                                },
                                                                "required": [
                                                                    "url",
                                                                    "label",
                                                                    "active"
                                                                ]
                                                            }
                                                        },
                                                        "path": {
                                                            "type": [
                                                                "string",
                                                                "null"
                                                            ],
                                                            "description": "Base path for paginator generated URLs."
                                                        },
                                                        "per_page": {
                                                            "type": "integer",
                                                            "description": "Number of items shown per page.",
                                                            "minimum": 0
                                                        },
                                                        "to": {
                                                            "type": [
                                                                "integer",
                                                                "null"
                                                            ],
                                                            "description": "Number of the last item in the slice.",
                                                            "minimum": 1
                                                        },
                                                        "total": {
                                                            "type": "integer",
                                                            "description": "Total number of items being paginated.",
                                                            "minimum": 0
                                                        }
                                                    },
                                                    "required": [
                                                        "current_page",
                                                        "from",
                                                        "last_page",
                                                        "links",
                                                        "path",
                                                        "per_page",
                                                        "to",
                                                        "total"
                                                    ]
                                                }
                                            },
                                            "required": [
                                                "links",
                                                "meta"
                                            ]
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            },
            "post": {
                "operationId": "translations.store",
                "description": "Store a new translation entry for a locale and key combination and sync\nany provided context tags.",
                "summary": "Create a translation",
                "tags": [
                    "Translation"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/StoreTranslationRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "`TranslationResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/TranslationResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/translations/{translation}": {
            "get": {
                "operationId": "translations.show",
                "description": "Return a single translation resource with its locale, key, value, and\nassociated tags.",
                "summary": "Show a translation",
                "tags": [
                    "Translation"
                ],
                "parameters": [
                    {
                        "name": "translation",
                        "in": "path",
                        "required": true,
                        "description": "The translation ID",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "`TranslationResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/TranslationResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    }
                }
            },
            "put": {
                "operationId": "translations.update",
                "description": "Modify an existing translation and resync its tags so the export output\nreflects the latest content immediately.",
                "summary": "Update a translation",
                "tags": [
                    "Translation"
                ],
                "parameters": [
                    {
                        "name": "translation",
                        "in": "path",
                        "required": true,
                        "description": "The translation ID",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateTranslationRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "`TranslationResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "$ref": "#/components/schemas/TranslationResource"
                                        }
                                    },
                                    "required": [
                                        "data"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "$ref": "#/components/responses/ModelNotFoundException"
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearer": {
                "type": "http",
                "description": "Bearer API token created via the /api/tokens endpoint.",
                "scheme": "bearer"
            }
        },
        "schemas": {
            "IssueAccessTokenRequest": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email"
                    },
                    "password": {
                        "type": "string"
                    },
                    "device_name": {
                        "type": "string",
                        "maxLength": 100
                    }
                },
                "required": [
                    "email",
                    "password",
                    "device_name"
                ],
                "title": "IssueAccessTokenRequest"
            },
            "StoreTranslationRequest": {
                "type": "object",
                "properties": {
                    "locale": {
                        "type": "string",
                        "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$",
                        "maxLength": 12
                    },
                    "key": {
                        "type": "string",
                        "maxLength": 191
                    },
                    "value": {
                        "type": "string"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "maxLength": 64
                        }
                    }
                },
                "required": [
                    "locale",
                    "key",
                    "value"
                ],
                "title": "StoreTranslationRequest"
            },
            "TranslationCollection": {
                "type": "object",
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/TranslationResource"
                        }
                    }
                },
                "required": [
                    "data"
                ],
                "title": "TranslationCollection"
            },
            "TranslationResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "locale": {
                        "type": "string"
                    },
                    "key": {
                        "type": "string"
                    },
                    "value": {
                        "type": "string"
                    },
                    "tags": {
                        "type": "array",
                        "items": {}
                    },
                    "created_at": {
                        "type": "string"
                    },
                    "updated_at": {
                        "type": "string"
                    }
                },
                "required": [
                    "id",
                    "locale",
                    "key",
                    "value",
                    "tags",
                    "created_at",
                    "updated_at"
                ],
                "title": "TranslationResource"
            },
            "UpdateTranslationRequest": {
                "type": "object",
                "properties": {
                    "locale": {
                        "type": "string",
                        "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$",
                        "maxLength": 12
                    },
                    "key": {
                        "type": "string",
                        "maxLength": 191
                    },
                    "value": {
                        "type": "string"
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "maxLength": 64
                        }
                    }
                },
                "title": "UpdateTranslationRequest"
            }
        },
        "responses": {
            "ValidationException": {
                "description": "Validation error",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Errors overview."
                                },
                                "errors": {
                                    "type": "object",
                                    "description": "A detailed description of each field that failed validation.",
                                    "additionalProperties": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                }
                            },
                            "required": [
                                "message",
                                "errors"
                            ]
                        }
                    }
                }
            },
            "AuthenticationException": {
                "description": "Unauthenticated",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Error overview."
                                }
                            },
                            "required": [
                                "message"
                            ]
                        }
                    }
                }
            },
            "ModelNotFoundException": {
                "description": "Not found",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Error overview."
                                }
                            },
                            "required": [
                                "message"
                            ]
                        }
                    }
                }
            }
        }
    }
}